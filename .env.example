# RevenueCat — public iOS / Android SDK anahtarları
# Dashboard: https://app.revenuecat.com/projects/<your-project>/apps
# Bu değerler client-side kullanıldığı için "public" anahtarlar (secret server key DEĞİL).
# EXPO_PUBLIC_ prefix'i Expo SDK 49+ tarafından otomatik olarak runtime'a inject edilir.

EXPO_PUBLIC_REVENUECAT_IOS_API_KEY=appl_xxxxxxxxxxxxxxxxxxxxxxx
EXPO_PUBLIC_REVENUECAT_ANDROID_API_KEY=goog_xxxxxxxxxxxxxxxxxxxxxxx

# Entitlement identifier (RevenueCat dashboard → Project → Entitlements)
# Varsayılan: "premium"
EXPO_PUBLIC_REVENUECAT_ENTITLEMENT_ID=premium

# -------------------------------------------------------------------
# KULLANIM:
# 1) Local development:
#    cp .env.example .env  → .env'yi gerçek anahtarlarla doldur
#    npx expo start         → EXPO_PUBLIC_* otomatik inline edilir
#
# 2) EAS Build (production/preview):
#    Yöntem A (önerilen) — EAS Secrets:
#      eas secret:create --scope project --name EXPO_PUBLIC_REVENUECAT_IOS_API_KEY --value appl_...
#      eas secret:create --scope project --name EXPO_PUBLIC_REVENUECAT_ANDROID_API_KEY --value goog_...
#      eas secret:create --scope project --name EXPO_PUBLIC_REVENUECAT_ENTITLEMENT_ID --value premium
#    Yöntem B (daha az güvenli) — eas.json içinde profile.env bloğuna ekle.
#
# 3) iOS App Store Connect tarafında In-App Purchase capability'sinin AÇIK olduğundan
#    emin ol (App ID → Capabilities → In-App Purchase). EAS Build sırasında bu
#    capability provisioning profile'a otomatik dahil edilir.
#
# Native autolink: react-native-purchases SDK 10+ ile Expo SDK 54+ otomatik link olur.
# Ek bir Expo config plugin gerekmiyor; app.json'a plugin entry eklemene gerek yok.

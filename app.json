{
  "expo": {
    "name": "Lit",
    "slug": "lit",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/icon.png",
    "userInterfaceStyle": "dark",
    "newArchEnabled": true,
    "splash": {
      "image": "./assets/splash-icon.png",
      "resizeMode": "contain",
      "backgroundColor": "#ffffff"
    },
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "com.uygarcapar.lit",
      "googleServicesFile": "./GoogleService-Info.plist",
      "infoPlist": {
        "ITSAppUsesNonExemptEncryption": false,
        "NSMicrophoneUsageDescription": "Sesli mesaj gönderebilmen için mikrofon erişimine izin vermen gerekir.",
        "UIBackgroundModes": [
          "remote-notification"
        ]
      }
    },
    "android": {
      "adaptiveIcon": {
        "foregroundImage": "./assets/adaptive-icon.png",
        "backgroundColor": "#ffffff"
      },
      "package": "com.uygarcapar.lit",
      "googleServicesFile": "./google-services.json",
      "edgeToEdgeEnabled": true,
      "useNextNotificationsApi": true,
      "permissions": [
        "RECORD_AUDIO",
        "POST_NOTIFICATIONS"
      ]
    },
    "plugins": [
      [
        "expo-notifications",
        {
          "icon": "./assets/adaptive-icon.png",
          "color": "#f57656",
          "defaultChannel": "unitinder_notifications"
        }
      ],
      "expo-maps",
      "expo-status-bar",
      "expo-audio",
      "expo-image",
      "@react-native-firebase/app",
      "@react-native-firebase/messaging",
      [
        "expo-build-properties",
        {
          "ios": {
            "extraPods": [
              { "name": "GoogleUtilities", "modular_headers": true },
              { "name": "FirebaseCoreInternal", "modular_headers": true },
              { "name": "FirebaseCore", "modular_headers": true },
              { "name": "FirebaseInstallations", "modular_headers": true }
            ]
          }
        }
      ]
    ],
    "web": {
      "favicon": "./assets/favicon.png"
    },
    "extra": {
      "eas": {
        "projectId": "6ba3a4c5-832e-4996-8c40-bf0a66b678ec"
      }
    },
    "owner": "uygarcapar"
  }
}

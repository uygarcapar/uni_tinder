{
  "extends": "./tsconfig.json",
  "compilerOptions": {
    "types": ["jest"],
    "noEmit": true
  },
  "include": [
    "nativewind-env.d.ts",
    "jest.setup.ts",
    "tests/**/*.test.ts",
    "tests/**/*.test.tsx",
    "src/__mocks__/**/*.ts",
    "src/__mocks__/**/*.tsx",
    "src/shared/components/__mocks__/**/*.ts",
    "src/shared/components/__mocks__/**/*.tsx"
  ]
}
